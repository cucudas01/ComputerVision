# Byte-compiled / optimized / DLL files (파이썬 실행 시 생기는 캐시)
__pycache__/
*.py[cod]
*$py.class
*.dll

# Virtual Environments (가상 환경 - 가장 중요! 절대 올리지 마세요)
.venv/
venv/
env/
ENV/

# VS Code (개인 설정 파일)
.vscode/

# Datasets (CIFAR-10 등 다운로드된 데이터셋)
*.tar.gz
*.zip
data/

# Models and Weights (학습된 모델 파일 - 용량이 큼)
*.h5
*.keras
*.model
*.weights

# Plots and results (결과 이미지 및 로그)
result.png
*.log

# OS files (OS 생성 임시 파일)
Thumbs.db
.DS_Store

# User-specific files
.env